FROM alpine:3.22

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata \
  && addgroup -S tick-sync \
  && adduser -S -G tick-sync tick-sync

COPY ${TARGETPLATFORM}/tick-sync /usr/bin/tick-sync

USER tick-sync
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1:8080/healthz || exit 1

ENTRYPOINT ["/usr/bin/tick-sync"]
