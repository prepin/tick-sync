GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_TOKEN_TYPE=Bearer
GOOGLE_TOKEN_EXPIRY=2026-06-10T12:00:00Z
GOOGLE_TASKLIST_ID=@default
GOOGLE_POST_SYNC_ACTION=complete

DB_PATH=./tick-sync.db
POLL_INTERVAL=5m

TICKTICK_ACCESS_TOKEN=your-ticktick-access-token
TICKTICK_API_BASE_URL=https://api.ticktick.com/open/v1
TICKTICK_TIME_ZONE=UTC
TICKTICK_PROJECT_ID=
